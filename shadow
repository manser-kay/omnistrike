#!/bin/bash
# Argus Red — Unified CLI
VERSION="56.1"

case "${1:-help}" in
    scan)    ~/argus.sh "${@:2}" ;;
    passive) python3 ~/argus_passive.py "${2:-9990}" ;;
    c2)      python3 ~/argus_ws_c2_server.py "${2:-8765}" ;;
    hunt)    ~/argus_hunt.sh "${2}" "${3}" ;;
    predict) ~/argus_predictor.sh "${2}" ;;
    whisper) ~/argus_whisper.sh "${2}" ;;
    echo)    ~/argus_echo.sh "${2}" ;;
    lie)     ~/argus_lie_detector.sh "${2}" ;;
    version) echo "Argus Red v$VERSION" ;;
    help)    cat << HELP
Argus Red v$VERSION — Red Team Framework

Команды:
  scan       Полное сканирование
  passive    Пассивный сканер (прокси)
  c2         C2 сервер
  hunt       Охота на технологию
  predict    Предсказать уязвимости
  whisper    Пассивная разведка
  echo       Детект WAF
  lie        Детектор лжи сервера
  version    Версия

Примеры:
  argus scan http://target.com
  argus hunt grafana http://target.com:3000
  argus whisper target.com
HELP
    ;;
    *)        ~/argus.sh "${@}" ;;
esac
